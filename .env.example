# ─── Frontend (Vite) ─────────────────────────────────────────
# All VITE_ prefixed vars are available in the browser via import.meta.env

VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_ID

# Legacy fallback (optional, kept for backward compatibility)
# VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_KEY

# Backend API URL (defaults to http://127.0.0.1:8000 if omitted)
VITE_AI_SERVICE_URL=http://127.0.0.1:8000

# ─── Backend (FastAPI / ai_services) ─────────────────────────
# These are loaded via python-dotenv and are NOT exposed to the browser

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
